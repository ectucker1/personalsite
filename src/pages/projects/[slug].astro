---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import type { ImageMetadata } from "astro";
import { Picture } from "astro:assets";

export async function getStaticPaths() {
    const projects = await getCollection("projects");
    return projects.map((project) => {
        const slug = project.id.split("/").pop() ?? project.id;
        return {
            params: { slug },
            props: { project },
        };
    });
}

const { project } = Astro.props;
const projectImages = import.meta.glob<{ default: ImageMetadata }>(
    "/src/projects/**/*.{jpeg,jpg,png,gif}",
);
const projectDocPath = "/" + project.filePath;
const projectImagePath =
    projectDocPath.substring(0, projectDocPath.lastIndexOf("/")) +
    "/" +
    project.data.preview_img;

const { Content } = await render(project);
---

<BaseLayout title={project.data.title}>
    <div class="section-title-break">
        <h2 class="tagged-header">{project.data.title}</h2>
        <span class="tag-date"
            >{project.data.start_date} - {project.data.end_date}</span
        >
    </div>
    <div class="section-generic">
        <Picture src={projectImages[projectImagePath]()} alt="" />
        <Content />
    </div>
</BaseLayout>
