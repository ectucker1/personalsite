---
import { getCollection, render } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import { displayDate } from "@data/date";

export async function getStaticPaths() {
    const posts = await getCollection("blog");
    return posts.map((post) => {
        const d = post.data.date;
        const year = String(d.getUTCFullYear());
        const month = String(d.getUTCMonth() + 1).padStart(2, "0");
        const day = String(d.getUTCDate()).padStart(2, "0");
        const slug = post.id.split("/").pop() ?? post.id;
        return {
            params: { year, month, day, slug },
            props: { post },
        };
    });
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={post.data.title}>
    <div class="section-title-break">
        <h2 class="tagged-header">{ post.data.title }</h2>
        <span class="tag-date">{ displayDate(post.data.date) }</span>
    </div>
    <div class="section-generic">
        <Content />
    </div>
</BaseLayout>
