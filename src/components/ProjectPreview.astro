---
import { projectUrl } from "@data/project";
import { render } from "astro:content";
import type { ImageMetadata } from "astro";
import { Picture } from "astro:assets";

const { project } = Astro.props;
const { Content } = await render(project);
const projectImages = import.meta.glob<{ default: ImageMetadata }>(
    "/src/projects/**/*.{jpeg,jpg,png,gif}",
);
const projectDocPath = "/" + project.filePath;
const projectImagePath =
    projectDocPath.substring(0, projectDocPath.lastIndexOf("/")) +
    "/" +
    project.data.preview_img;
---

{
    project.data.preview_img === undefined ? (
        <div class="section-generic">
            <div class="poster-project-header-block">
                <a class="clear-link" href={projectUrl(project)}>
                    <h3 class="tagged-header">{project.data.title}</h3>
                </a>
                <span class="tag-date">
                    {project.data.start_date} - {project.data.end_date}
                </span>
            </div>
            <div class="poster-project-text-content">
                <Content preview />
                <a class="readmore" href={projectUrl(project)}>
                    Read More
                </a>
            </div>
        </div>
    ) : (
        <div class="section-poster-project">
            <div class="poster-project-image-column">
                <a class="clear-link" href={projectUrl(project)}>
                    <Picture src={projectImages[projectImagePath]()} alt="" />
                </a>
            </div>
            <div class="poster-project-text-column">
                <div class="poster-project-header-block">
                    <a class="clear-link" href={projectUrl(project)}>
                        <h3 class="tagged-header">{project.data.title}</h3>
                    </a>
                    <span class="tag-date">
                        {project.data.start_date} - {project.data.end_date}
                    </span>
                </div>
                <div class="poster-project-text-content">
                    <Content preview />
                    <a class="readmore" href={projectUrl(project)}>
                        Read More
                    </a>
                </div>
            </div>
        </div>
    )
}
