---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" sizes="32x32" />
        <meta name="generator" content={Astro.generator} />
        <title>{title ? `${title} - ectcetera` : "ectcetera"}</title>
        <link rel="sitemap" href="/sitemap-index.xml" />
        <link
            rel="preload"
            href="/fonts/figtree/Figtree-Medium.woff2"
            as="font"
            type="font/woff2"
            crossorigin
        />
        <link
            rel="preload"
            href="/fonts/electrolize/Electrolize-Regular.woff2"
            as="font"
            type="font/woff2"
            crossorigin
        />
        <link
            rel="preload"
            href="/fonts/ectcetera-icons/ectcetera-icons.woff2"
            as="font"
            type="font/woff2"
            crossorigin
        />
        <link
            rel="preload"
            href="/images/herringbone.webp"
            as="image"
            type="image/webp"
        />
        <link
            href="/blog/atom.xml"
            type="application/atom+xml"
            rel="alternate"
            title="Blog Atom/RSS Feed"
        />
    </head>
    <body>
        <div class="page">
            <Header />
            <main>
                <slot />
            </main>
            <Footer />
        </div>
    </body>
</html>
